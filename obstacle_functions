%% function for updating bike

function [y_bike,x_bike, dy_bike] = update_bike(y_bike, dy_bike, x_bike, ymin, ymax)

    y_bike= y_bike + dy_bike; %update bike motion 
    if y_bike > ymax || y_bike < ymin  %check if reaching boundary. Switch motion direction if so 
        dy_bike = -dy_bike; 
    end 
     x_bike= 2300 + 20*cos(0.7*y_bike/50); %motion bike for x depends on y 
    end 


%% function for updating bluecar
function[y_bluecar, dy_bluecar]= update_cars(y_bluecar, dy_bluecar, ymin, ymax)

    x_bluecar=2450; %constant because going in straight line 
    y_bluecar= y_bluecar; %update car motion 
    if y_bluecar>ymax %boundary condition 
        y_bluecar=ymin; 
    end
    y_bluecar= y_bluecar + dy_bluecar; %motion equation for car 



