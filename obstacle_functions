            otherwise 
                
    end
end



%% drawing function (image rendering for car)
    function draw_cars(hbluecar, hcar, x_bluecar, y_bluecar,numCars, ymin, ymax, p, q, p_4, q_4)

    roadlength= ymax-ymin; 

    %update bluecar image 
    hbluecar =image(bluecar, ...
        'Xdata', [x_bluecar-q/2, x_bluecar+q/2], ...
        'Ydata', [y_bluecar-p/2, y_bluecar+p/2], ...
        'AlphaData', bluecar_alpha); 
    
    
    %follower car 
        for i=1:numCars
            y_i = y_bluecar + offsets(i); 
            if y_i< ymin
                y_i=y_i + roadlength; %continues motion for length left once lead car is deleted 
            end 
            set(hcar(i), ...
                'Xdata', [2450-q_4/2, 2450+q_4/2], ...
                'Ydata', [y_i -p_4/2, ...
                          y_i + p_4/2], ...
                'AlphaData', car_alphas{i});
        end




